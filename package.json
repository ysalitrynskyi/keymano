{
  "name": "keymano",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "description": "Cross-platform editor for macOS .keylayout files and .bundle keyboard packages, with a live clickable keyboard.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "author": "Yevhen Salitrynskyi",
  "homepage": "https://github.com/ysalitrynskyi/keymano",
  "repository": {
    "type": "git",
    "url": "https://github.com/ysalitrynskyi/keymano.git"
  },
  "bugs": {
    "url": "https://github.com/ysalitrynskyi/keymano/issues"
  },
  "keywords": [
    "keyboard-layout",
    "keylayout",
    "macos",
    "tauri",
    "ukelele",
    "keyboard",
    "i18n"
  ],
  "scripts": {
    "wasm:build": "wasm-pack build crates/keymano-wasm --target web --out-dir ../../src/wasm --out-name keymano_wasm",
    "dev": "pnpm wasm:build && vite",
    "build": "pnpm wasm:build && tsc -b && vite build",
    "preview": "vite preview",
    "test": "pnpm wasm:build && vitest run",
    "test:watch": "vitest",
    "coverage": "pnpm wasm:build && vitest run --coverage",
    "lint": "eslint .",
    "tauri": "tauri"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}

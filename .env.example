# ===========================================
# Keymano — production deployment (.env)
# ===========================================
# Copy to `.env` next to docker-compose.prod.yml, then:
#   docker compose -f docker-compose.prod.yml up -d
# In Portainer, set these under the stack's Environment variables instead.

# Cloudflare Zero Trust tunnel token (REQUIRED).
# Zero Trust dashboard → Networks → Tunnels → (your tunnel) → install token.
# Add a public hostname route on that tunnel:
#   keymano.ys.contact  ->  http://keymano:80
CLOUDFLARE_TUNNEL_TOKEN=

# Image/tag to run (OPTIONAL — defaults to the latest published build).
# KEYMANO_IMAGE=ghcr.io/ysalitrynskyi/keymano:latest

# Google Analytics measurement id (OPTIONAL — analytics is OFF by default).
# Set this to your GA4 id (e.g. G-XXXXXXXXXX) to inject the Google tag into the
# hosted page and widen the CSP to Google's analytics origins. Leave empty (or
# omit) to serve a fully same-origin, cookie-free page with no analytics or
# third-party script. Change/clear it and restart the container to toggle —
# no rebuild needed. NOTE: enabling this loads Google's script and sets GA
# cookies; make sure your deployment's privacy/consent obligations are met.
GA_MEASUREMENT_ID=

# Cloudflare Web Analytics (OPTIONAL — OFF by default).
# If this site sits behind a Cloudflare tunnel/zone with automatic Web
# Analytics enabled, the CF edge injects its beacon script into the page. Set
# this to 1 to allow the CF beacon origins in the CSP (otherwise the browser
# blocks it and logs a console error). Leave empty to keep the CSP same-origin;
# if you don't want CF analytics at all, also turn off the automatic beacon in
# the Cloudflare Web Analytics dashboard. Restart the container to toggle.
CLOUDFLARE_WEB_ANALYTICS=
